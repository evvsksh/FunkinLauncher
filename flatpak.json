{
  "app-id": "it.evvsk.FunkinLauncher",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "funkinlauncher",
  "runtime-extensions": ["org.freedesktop.Platform.ffmpeg-full"],
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=all",
    "--filesystem=home:exec"
  ],
  "modules": [
    {
      "name": "vlc",
      "buildsystem": "autotools",
      "config-opts": ["--disable-lua", "--disable-nls", "--disable-rpath"],
      "build-options": {
        "env": {
          "CC": "gcc",
          "CXX": "g++",
          "BUILDCC": "gcc"
        }
      },
      "sources": [
        {
          "type": "archive",
          "url": "https://videolan.mirror.garr.it/mirrors/videolan/vlc/3.0.21/vlc-3.0.21.tar.xz",
          "sha256": "24dbbe1d7dfaeea0994d5def0bbde200177347136dbfe573f5b6a4cee25afbb0"
        }
      ]
    },
    {
      "name": "funkin-launcher",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 funkinlauncher /app/bin/funkinlauncher"
      ],
      "sources": [
        {
          "type": "file",
          "path": "src-tauri/target/release/funkinlauncher"
        }
      ]
    }
  ]
}
