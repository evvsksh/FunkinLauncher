{
  "app-id": "it.evvsk.FunkinLauncher",

  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",

  "command": "funkinlauncher",

  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=all",
    "--filesystem=home:exec"
  ],

  "add-extensions": {
    "org.videolan.VLC": {
      "directory": "lib/vlc",
      "version": "4.0"
    }
  },

  "modules": [
    {
      "name": "ffmpeg",
      "config-opts": [
        "--enable-shared",
        "--disable-static",
        "--disable-doc",
        "--disable-debug",
        "--enable-gpl",
        "--enable-version3"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://ffmpeg.org/releases/ffmpeg-4.4.tar.xz",
          "sha256": "06b10a183ce5371f915c6bb15b7b1fffbe046e8275099c96affc29e17645d909"
        }
      ]
    },

    {
      "name": "libvlc",
      "config-opts": [
        "BUILDCC=gcc",
        "--disable-lua",
        "--disable-a52",
        "--disable-qt",
        "--disable-ncurses",
        "--disable-udev"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://get.videolan.org/vlc/3.0.21/vlc-3.0.21.tar.xz",
          "sha256": "24dbbe1d7dfaeea0994d5def0bbde200177347136dbfe573f5b6a4cee25afbb0",
          "x-checker-data": {
            "type": "anitya",
            "project-id": 6504,
            "stable-only": true,
            "url-template": "https://get.videolan.org/vlc/$version/vlc-$version.tar.xz"
          }
        }
      ]
    },

    {
      "name": "funkin-launcher",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 funkinlauncher /app/bin/funkinlauncher"
      ],
      "sources": [
        {
          "type": "file",
          "path": "src-tauri/target/release/funkinlauncher"
        }
      ]
    }
  ]
}
