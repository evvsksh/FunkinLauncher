{
  "app-id": "it.evvsk.FunkinLauncher",

  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",

  "command": "funkinlauncher",

  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=all",
    "--filesystem=home:exec"
  ],

  "modules": [
    {
      "name": "vlc-runtime",
      "buildsystem": "simple",
      "build-commands": [
        "cp /usr/lib/x86_64-linux-gnu/libvlc.so.5 /app/lib/",
        "cp /usr/lib/x86_64-linux-gnu/libvlccore.so.9 /app/lib/",
        "cp -r /usr/lib/vlc /app/lib/"
      ]
    },
    {
      "name": "funkin-launcher",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 funkinlauncher /app/bin/funkinlauncher"
      ],
      "sources": [
        {
          "type": "file",
          "path": "src-tauri/target/release/funkinlauncher"
        }
      ]
    }
  ]
}
