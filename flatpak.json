{
  "app-id": "it.evvsk.FunkinLauncher",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "funkinlauncher",
  "runtime-extensions": ["org.freedesktop.Platform.ffmpeg-full"],
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=all",
    "--filesystem=home:exec"
  ],
  "modules": [
    {
      "name": "funkin-launcher",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 funkinlauncher /app/bin/funkinlauncher"
      ],
      "sources": [
        {
          "type": "file",
          "path": "src-tauri/target/release/funkinlauncher"
        }
      ]
    },
    {
      "name": "ffmpeg",
      "buildsystem": "autotools",
      "config-opts": [
        "--enable-shared",
        "--disable-static",
        "--enable-gpl",
        "--enable-nonfree",
        "--enable-pic"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://ffmpeg.org/releases/ffmpeg-5.1.6.tar.xz",
          "sha256": "f4fa066278f7a47feab316fef905f4db0d5e9b589451949740f83972b30901bd"
        }
      ]
    },
    {
      "name": "vlc",
      "buildsystem": "autotools",
      "config-opts": [
        "--disable-lua",
        "--disable-nls",
        "--disable-skins2",
        "--disable-udev",
        "--disable-dbus",
        "--disable-sdl",
        "--disable-a52",
        "--enable-avcodec",
        "--with-libavcodec=ffmpeg"
      ],
      "build-options": {
        "env": {
          "PKG_CONFIG_PATH": "/app/lib/pkgconfig:/app/usr/lib/pkgconfig",
          "CFLAGS": "-I/app/include",
          "CXXFLAGS": "-I/app/include",
          "LDFLAGS": "-L/app/lib",
          "CC": "ccache gcc",
          "CXX": "ccache g++",
          "BUILDCC": "gcc"
        }
      },
      "sources": [
        {
          "type": "archive",
          "url": "https://get.videolan.org/vlc/3.0.21/vlc-3.0.21.tar.xz",
          "sha256": "24dbbe1d7dfaeea0994d5def0bbde200177347136dbfe573f5b6a4cee25afbb0"
        }
      ]
    }
  ]
}
