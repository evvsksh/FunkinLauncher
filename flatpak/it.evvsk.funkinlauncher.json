{
    "app-id": "it.evvsk.FunkinLauncher",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "funkin-launcher",

    "sdk-extensions": ["org.freedesktop.Sdk.Extension.node20"],

    "build-options": {
        "append-path": "/usr/lib/sdk/node20/bin:/usr/bin"
    },

    "finish-args": [
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--device=all",
        "--filesystem=home"
    ],

    "modules": [
        {
            "name": "funkin-launcher",
            "buildsystem": "simple",
            "build-commands": [
                "npm ci --no-audit --no-fund",
                "npm run build",
                "install -Dm755 dist/index.html /app/share/funkin-launcher/index.html",
                "printf '#!/bin/sh\nxdg-open /app/share/funkin-launcher/index.html' > /app/bin/funkin-launcher",
                "chmod +x /app/bin/funkin-launcher"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}
