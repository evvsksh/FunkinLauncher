{
    "app-id": "it.evvsk.FunkinLauncher",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "funkin-launcher",

    "finish-args": [
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--device=all",
        "--filesystem=home"
    ],

    "sdk-extensions": ["org.freedesktop.Sdk.Extension.node20"],

    "build-options": {
        "append-path": "/usr/lib/sdk/node20/bin",
        "env": {
            "NODE_ENV": "production"
        },
        "build-args": ["--share=network"]
    },

    "modules": [
        {
            "name": "funkin-launcher",
            "buildsystem": "simple",
            "build-commands": [
                "npm ci --no-audit --no-fund",
                "export PATH=$PWD/node_modules/.bin:$PATH",
                "node -v",
                "npm -v",
                "which tsc",
                "npm run build",
                "mkdir -p /app/share/funkin-launcher",
                "cp -r dist/* /app/share/funkin-launcher/",
                "install -Dm755 /bin/true /app/bin/funkin-launcher"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}
