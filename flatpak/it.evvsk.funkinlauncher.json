{
    "app-id": "it.evvsk.FunkinLauncher",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "funkin-launcher",

    "finish-args": [
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--device=all",
        "--filesystem=home"
    ],

    "modules": [
        {
            "name": "funkin-launcher",
            "buildsystem": "simple",
            "build-commands": [
                "npm ci --no-audit --no-fund",
                "npm run build",
                "mkdir -p /app/share/funkin-launcher",
                "cp -r dist/* /app/share/funkin-launcher/",
                "install -Dm755 /bin/true /app/bin/funkin-launcher"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}
