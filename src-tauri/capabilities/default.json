{
    "identifier": "default",
    "description": "Main window capabilities",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "opener:default",
        "core:path:default",
        "fs:default",
        {
            "identifier": "fs:scope",
            "allow": [{ "path": "$EXE/mods" }, { "path": "$EXE/mods/**" }]
        },

        {
            "identifier": "webview:allow-navigation",
            "allow": ["https://*.gamebanana.com"]
        }
    ]
}
