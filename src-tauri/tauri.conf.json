{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Funkin Launcher",
    "version": "1.0.0",
    "identifier": "it.evvsk.funkinlauncher",

    "build": {
        "beforeDevCommand": "npm run vite",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run vite build",
        "frontendDist": "../dist"
    },

    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Funkin' Launcher",
                "width": 950,
                "height": 600,
                "resizable": false,
                "fullscreen": false,
                "center": true
            }
        ],
        "security": {
            "csp": {
                "default-src": "'self'",
                "connect-src": "'self' https://gamebanana.com https://*.gamebanana.com https://images.gamebanana.com",
                "img-src": "'self' https://gamebanana.com https://*.gamebanana.com https://images.gamebanana.com",
                "media-src": "'self' https://gamebanana.com https://*.gamebanana.com https://images.gamebanana.com"
            },
            "capabilities": ["default"]
        }
    },

    "bundle": {
        "active": true,
        "targets": ["msi"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.png",
            "icons/icon.ico"
        ],
        "resources": ["resources/7z/win/*", "resources/7z/linux/*"]
    }
}
