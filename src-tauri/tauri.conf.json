{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Funkin Launcher",
    "version": "1.0.0",
    "identifier": "it.evvsk.funkinlauncher",

    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },

    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Funkin' Launcher",
                "width": 950,
                "height": 600,
                "resizable": false,
                "fullscreen": false,
                "center": true
            }
        ],
        "security": {
            "csp": null,
            "capabilities": ["default"]
        }
    },

    "bundle": {
        "active": true,
        "targets": ["msi"]
    }
}
