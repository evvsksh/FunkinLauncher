{
    "productName": "Funkin Launcher",
    "version": "1.0.0-beta",
    "identifier": "it.evvsk.funkinlauncher",
    "build": {
        "beforeBuildCommand": "npm run build",
        "beforeDevCommand": "npm run dev",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Funkin' Launcher",
                "width": 950,
                "height": 600,
                "resizable": false,
                "fullscreen": false,
                "center": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
